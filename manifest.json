{
  "manifest_version": 3,
  "name": "Playbook",
  "version": "1.0",
  "description": "Floating sidebar to build, organize, and export interview prep notes with full rich-text formatting.",
  "permissions": ["storage", "activeTab", "scripting"],
  "action": {
    "default_title": "Open Playbook"
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "sidebar.html",
        "sidebar.css",
        "sidebar.js",
        "lib/Sortable.min.js",
        "lib/html2pdf.bundle.min.js"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
